# 4Dpapers — environment variable reference
# Copy this file to .env and fill in the values.
# The .env file is loaded automatically by Docker Compose.

# ── Authentication ────────────────────────────────────────────────────────────
# Shared secret that all API clients must send in the X-API-Key header.
# Leave empty / unset to disable authentication (local single-user mode).
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
FOURD_API_KEY=

# Local single-user convenience: with no FOURD_API_KEY set, the server refuses
# to start on a network-reachable address to avoid accidentally exposing an
# unauthenticated instance. This flag opts into running unauthenticated, which
# is fine for `docker compose up` on your own machine. NEVER set this in
# production — set FOURD_API_KEY there instead (see .env.production.example).
FOURD_ALLOW_INSECURE=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin that is permitted to make cross-origin requests to the backend.
# Default: http://localhost:5006  (correct for local use)
# Change this when running behind a reverse proxy or on a custom port/domain.
FOURD_ALLOWED_ORIGIN=http://localhost:5006

# ── AI Providers ──────────────────────────────────────────────────────────────
# Ollama endpoint (default works for Docker on Mac/Windows via host.docker.internal)
OLLAMA_URL=http://host.docker.internal:11434/api/chat

# Set either key to enable that provider in the AI sidebar.
# Leave blank to hide the provider from the UI entirely.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Expose agent persona metadata at /api/agents (0 = hidden, 1 = public)
FOURD_EXPOSE_AGENTS=0

# ── Cryptographic HTML signing (Trust) ───────────────────────────────────────
# To enable signing, mount PEM files into the container and point these env vars
# at those mounted paths. Do not store the private key under /workspace/state or
# anywhere else that the app serves over HTTP.
#
# Example read-only bind mount in Docker Compose:
#   - /absolute/host/path/4dpapers-keys:/run/secrets/4dpapers:ro
#
# Generate a keypair locally with:
#   python scripts/generate_signing_keys.py \
#     --private-key /absolute/host/path/4dpapers-keys/private.pem \
#     --public-key  /absolute/host/path/4dpapers-keys/public.pem
FOURD_SIGNING_KEYS_HOST_DIR=
FOURD_SIGNING_PRIVATE_KEY_PATH=
FOURD_SIGNING_PUBLIC_KEY_PATH=
FOURD_SIGNING_KEY_ID=default

# ── Docker / server ───────────────────────────────────────────────────────────
# Host folder mounted by docker compose at /workspace.
# Use ./workspace for a new local paper, or set an absolute path to edit an existing paper.
FOURD_WORKSPACE=./workspace
PORT=5006
PYTHONUNBUFFERED=1
PROJECT_ROOT=/workspace
