# 4Dpapers — single-host production example
# Usage:
#   cp .env.production.example .env.production
#   edit values
#   docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up -d

# Ensure the service container loads this same file as its env_file.
FOURD_ENV_FILE=.env.production

# Public HTTPS hostname served by Caddy.
APP_DOMAIN=paper.example.com
ACME_EMAIL=ops@example.com

# Bind the app to loopback only. Caddy handles public ingress.
FOURD_APP_PUBLISH=127.0.0.1:5006:5006
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Prefer the published image for remote deployments. Pin to an explicit version
# (or digest) rather than :latest so rollbacks have a fixed target.
IMAGE=ghcr.io/svcheidi/4dpaper:0.1.0

# Workspace mounted into /workspace inside the app container.
FOURD_WORKSPACE=/srv/4dpapers/workspace

# Production hardening: drop to the bundled unprivileged runtime user after
# workspace initialization. Enable chown on dedicated hosts so authored files
# remain writable by the app user.
FOURD_DROP_PRIVILEGES=1
FOURD_CHOWN_WORKSPACE=1

# Required for network-accessible deployments.
# REQUIRED. Authentication is fail-open: if this is unset the server refuses to
# start on a network-reachable address (see serve.py / dashboard.auth). Use a
# long random secret, e.g.  openssl rand -hex 32
FOURD_API_KEY=replace-with-a-long-random-secret
FOURD_ALLOWED_ORIGIN=https://paper.example.com

# Optional assistant providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434/api/chat
FOURD_EXPOSE_AGENTS=0

# Optional signing keys. Keep these outside the workspace.
FOURD_SIGNING_KEYS_HOST_DIR=/srv/4dpapers/keys
FOURD_SIGNING_PRIVATE_KEY_PATH=/run/secrets/4dpapers/private.pem
FOURD_SIGNING_PUBLIC_KEY_PATH=/run/secrets/4dpapers/public.pem
FOURD_SIGNING_KEY_ID=default

PORT=5006
PYTHONUNBUFFERED=1
PROJECT_ROOT=/workspace
